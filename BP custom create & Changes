            select single a~gpart from dfkk_ma_h as a inner join

                                       dfkk_ma_bp as b on b~aguid = a~aguid

              into @data(v_gpart_p) where b~gpart = @lwa_bp_create-bu_partner.

            if v_gpart_p is not initial and ( v_gpart_p ne lv_bupnm ).

              message e016(zotc_bp) with v_gpart_p into lwa_return-message.

              mac_sy_messages lwa_return.

              lwa_return-parameter = zcl_ts_constants=>c_para_bupa.

              append lwa_return to re_return.

              clear lwa_return.

            endif.

          else.

            message e000(zotc_bp) with text-e07 into lwa_return-message.

            mac_sy_messages lwa_return.

            lwa_return-parameter = zcl_ts_constants=>c_para_bupa.

            append lwa_return to re_return.

            clear lwa_return.

