Odata : create 2 deep entity set sales where partner details are maintained & for general credit & contractaccount & companycode & sales are maintained

Purpose              : Inbound From ECC to S4 / Inbound From Impulse to S4 BP create

*                        Create Odata service to create and change the business partners

*                        custom Bapi is created and is handling 7 views of customer master

*                        and it is called in custom odata service.


  METHOD /iwbep/if_mgw_appl_srv_runtime~create_deep_entity.

    DATA: lwa_deep_entity       TYPE zcl_zi_gbl_ar_customer_mpc_ext=>t_deep_entity,

          li_deep_entity        TYPE STANDARD TABLE OF zcl_zi_gbl_ar_customer_mpc_ext=>t_deep_entity,

          lwa_deep_entity_sales TYPE zcl_zi_gbl_ar_customer_mpc_ext=>t_sales.

**Structures

    DATA: li_bp_create   TYPE STANDARD TABLE OF zotc_brim_bupa_create,

          lwa_bp_create  TYPE zotc_brim_bupa_create,

          lwa_ca_create  TYPE zotc_brim_ctracct_create,

          lwa_cms_create TYPE zotc_brim_cms_create,

          li_sales       TYPE STANDARD TABLE OF zotc_brim_sd_create,

          lwa_sales      TYPE zotc_brim_sd_create,

          lwa_cc_create  TYPE zotc_brim_cc_create,

          lwa_cp_create  TYPE zotc_brim_cont_create.

    DATA: lv_country_code TYPE land1,

          lv_market_place TYPE char6,

          lv_partner      TYPE bu_partner,

          li_partner      TYPE STANDARD TABLE OF zotc_brim_partners_create,

          lwa_partner     TYPE zotc_brim_partners_create,

          li_contact      TYPE STANDARD TABLE OF zotc_brim_cont_create,

          lwa_contact     TYPE zotc_brim_cont_create,

          li_return       TYPE STANDARD TABLE OF zotc_brim_return,

          li_return2      TYPE bapiret2_t,

          lwa_return2     LIKE LINE OF li_return2,

          lv_errmsg       TYPE bapi_msg,

          lo_msg          TYPE REF TO /iwbep/if_message_container.

    CONSTANTS : lc_e TYPE string VALUE 'E',

                lc_s TYPE c VALUE 'S'.

    FIELD-SYMBOLS: <fs_sales> TYPE zcl_zi_gbl_ar_customer_mpc_ext=>t_sales.

    " Read data from payload

    TRY.

        io_data_provider->read_entry_data(

          IMPORTING

            es_data = lwa_deep_entity ).

      CATCH /iwbep/cx_mgw_tech_exception INTO DATA(lx_tech).

        lo_msg = me->mo_context->get_message_container( ).

        lo_msg->add_message_from_exception(

          io_exception              = lx_tech

          iv_message_target         =  lc_e

          iv_add_to_response_header = abap_true ).

        RAISE EXCEPTION TYPE /iwbep/cx_mgw_busi_exception

          EXPORTING

            message_container = lo_msg.

    ENDTRY.

    IF lwa_deep_entity IS NOT INITIAL.

*mapping for FM inputs

      lwa_bp_create = CORRESPONDING #( lwa_deep_entity ).

      lwa_ca_create  = CORRESPONDING #( lwa_deep_entity-to_contractaccount ). "OPTIONAL ).

      lwa_cms_create = CORRESPONDING #( lwa_deep_entity-to_credit ).

      lwa_cc_create  = CORRESPONDING #( lwa_deep_entity-to_companycode ).

      lwa_sales      = CORRESPONDING #( lwa_deep_entity-to_sales ).

      APPEND LINES OF lwa_deep_entity-to_sales-to_partner TO li_partner.

      li_contact = VALUE #( BASE li_contact ( LINES OF lwa_deep_entity-to_contact ) ).

      lv_market_place = lwa_deep_entity-oa_mktplace_id.

**Begin of insert of logic of country code for impulse INMEHS04

      IF lwa_deep_entity-country IS INITIAL.

        SELECT SINGLE partner,

               bpext

               FROM but000

               INTO @DATA(lwa_ext_no)

               WHERE bpext = @lwa_bp_create-bcn_num.

        IF sy-subrc IS INITIAL AND lwa_ext_no IS NOT INITIAL.

          SELECT SINGLE partner,

                 addrnumber

                 FROM but020

                 INTO @DATA(lwa_adr_no)

                 WHERE partner = @lwa_ext_no-partner.

            IF sy-subrc IS INITIAL AND lwa_adr_no IS NOT INITIAL.

              SELECT SINGLE addrnumber,

                     country

                     FROM adrc

                     INTO @DATA(lwa_countrycode_t)

                     WHERE addrnumber = @lwa_adr_no-addrnumber.

              IF sy-subrc IS INITIAL AND lwa_countrycode_t IS NOT INITIAL.

                lv_country_code = lwa_countrycode_t-country.

                lwa_bp_create-country = lv_country_code.

              ENDIF.

            ENDIF.

          ENDIF.

        ELSE.

          lv_country_code = lwa_deep_entity-country.

        ENDIF.

*End of Insert by INMEHS04.

        "Call Customer master FM for create and change scenario of business partners

        CALL FUNCTION 'ZOTC_CUST_BP_CREATE'

          EXPORTING

            im_bp_create       = lwa_bp_create

            im_ca_create       = lwa_ca_create

            im_cms_create      = lwa_cms_create

            im_sales_create    = lwa_sales

            im_ccode_create    = lwa_cc_create

            im_country_code    = lv_country_code

            im_market_place    = lv_market_place

          TABLES

            tb_partners_create = li_partner

            tb_contact_create  = li_contact

            tb_return_log      = li_return.

        IF li_return IS NOT INITIAL.

          READ TABLE li_return TRANSPORTING NO FIELDS WITH KEY ex_bu_partner = ''.

          IF sy-subrc IS INITIAL.

*        Error handling

            LOOP AT li_return INTO DATA(lwa_return).

              lwa_return2 = VALUE #( BASE lwa_return

              type       = lwa_return-type

              number     = lwa_return-number

              message    = lwa_return-message

               ).

              APPEND lwa_return2 TO li_return2[].

            ENDLOOP.

            LOOP AT li_return2 INTO lwa_return2.

              DATA(lo_msg1) = me->/iwbep/if_mgw_conv_srv_runtime~get_message_container( ).

              lo_msg1->add_message( iv_msg_type   = /iwbep/cl_cos_logger=>error

                                    iv_msg_id     = lwa_return2-id

                                    iv_msg_number = lwa_return2-number

                                    iv_msg_text = lwa_return2-message

                                  ).

            ENDLOOP.

            RAISE EXCEPTION NEW /iwbep/cx_mgw_busi_exception( message_container = lo_msg1 ). "#EC SCOPE_OF_VAR

          ENDIF.

          READ TABLE li_return TRANSPORTING NO FIELDS WITH KEY type = lc_e.

          IF sy-subrc IS INITIAL.

*        Error handling

            LOOP AT li_return INTO lwa_return.

              lwa_return2 = VALUE #( BASE lwa_return

              type       = lwa_return-type

              number     = lwa_return-number

              message    = lwa_return-message

               ).

              APPEND lwa_return2 TO li_return2[].

            ENDLOOP.

            LOOP AT li_return2 INTO lwa_return2.

              DATA(lo_msg2) = me->/iwbep/if_mgw_conv_srv_runtime~get_message_container( ).

              lo_msg2->add_message( iv_msg_type   = /iwbep/cl_cos_logger=>error

                                    iv_msg_id     = lwa_return2-id

                                    iv_msg_number = lwa_return2-number

                                    iv_msg_text = lwa_return2-message

                                  ).

            ENDLOOP.

            RAISE EXCEPTION NEW /iwbep/cx_mgw_busi_exception( message_container = lo_msg2 ). "#EC SCOPE_OF_VAR

          ELSE.

*in case of Success

            CLEAR lwa_return.

            READ TABLE li_return INTO lwa_return WITH KEY type = lc_s.

            IF sy-subrc IS INITIAL AND lwa_return-ex_bu_partner IS NOT INITIAL.

              lwa_deep_entity-bu_partner = lwa_return-ex_bu_partner.

            ENDIF.

            me->copy_data_to_ref(

               EXPORTING

                 is_data = lwa_deep_entity

               CHANGING

                 cr_data = er_deep_entity ).

          ENDIF.

        ENDIF.

      ENDIF.

    ENDMETHOD.

