    wa_ret_log-ex_bu_partner = ex_bu_partner .

    wa_ret_log-ex_cont_acct = ex_cont_acct .

    wa_ret_log-ex_suffix = ex_suffix .

    wa_ret_log-message = text-e06 .

    append wa_ret_log to tb_return_log .

