            lwa_return-parameter = zcl_ts_constants=>c_para_bupa.

            append lwa_return to re_return.

            clear lwa_return.

          endif.

        endif.

        select single makey from dfkk_ma_h                  "#EC WARNOK

            where gpart = @lv_bupnm

            into @data(lv_makey).

        if lv_makey is initial.

          if lwa_cms-xblocked = '8'.

            create_ma_parent = 'X'.

          else.

            message e000(zotc_bp) with text-e07 into lwa_return-message.

            mac_sy_messages lwa_return.

            lwa_return-parameter = zcl_ts_constants=>c_para_bupa.

            append lwa_return to re_return.

            clear lwa_return.

          endif.

        else.

