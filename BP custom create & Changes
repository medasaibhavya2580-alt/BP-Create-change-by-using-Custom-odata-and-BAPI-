    if im_cms_create is not initial.

      im_cms_create-credit_segment = '6021'.

    endif.

**End of insert by INMEHS04 for credit segment|18.02.2026| DS1K926511

  endif.

  lwa_bp_create-partn_typ = lc_ztsr.

*--- End of INS: USSHIA16/DS1K926511

  if lwa_bp_create-bcn_num is not initial.

    ex_bcn_num = lwa_bp_create-bcn_num.

    if lwa_bp_create-zz_parentbcn is not initial and 1 = 2.

      select single partner                                 "#EC WARNOK

        from but000

        into @data(lv_bupnm)

        where bpext = @lwa_bp_create-zz_parentbcn

             and bu_group = @zcl_ts_constants=>c_ztr1 .

      if sy-subrc = 0.

        select single @abap_true from dfkk_ma_bp

           where gpart = @lv_bupnm into @data(v_exists_bp).

        if v_exists_bp is not initial.

          select single @abap_true from dfkk_ma_h

             where gpart = @lv_bupnm into @data(v_exists_h).

          if v_exists_h is initial.

