*<< SOC Company code population

  clear lv_value.

  select single * into @data(lwa_country_ccode) from tvarvc "#EC CI_ALL_FIELDS_NEEDED

    where name = @im_country_code and type = 'S' and

      low = @im_market_place.                           "#EC CI_NOORDER

  if sy-subrc = 0.

    lv_value = lwa_country_ccode-high.

    lwa_contract-comp_code = lv_value.

    lwa_contract-std_comp_code = lv_value.

    lwa_cms-credit_segment = lv_value.

  else.

    clear : wa_ret_log .

