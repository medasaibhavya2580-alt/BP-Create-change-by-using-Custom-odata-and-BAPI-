  endif.

*<< EOC Company code population

  data(lwa_bp_create) = im_bp_create.

  if lwa_contract-bcn_num ne lwa_contract-bcn_num .

    clear : lwa_contract.

  endif.

  if lwa_cms-bcn_num ne lwa_bp_create-bcn_num .

    clear : lwa_cms .

  endif.

*  first we need to see if the country we are looking at needs the logic

  select single low

    into @data(lv_country)

    from ztec_params_tab

    where progname = @zcl_ts_constants=>c_prog_bpcreate

      and fieldname = 'Z_COUNTRY'

      and low = @lwa_bp_create-country.

  if sy-subrc = 0.

    if lwa_bp_create-postl_cod1 is not initial.

*      "removes any non numeric values

      replace all occurrences of regex '[^0-9]' in lwa_bp_create-postl_cod1 with ''.

      "fill in leading zeros IF needed -> does nothing if not

      lwa_bp_create-postl_cod1 = |{ lwa_bp_create-postl_cod1 width = 5 pad = '0' align = right }|.

    endif.

  endif.

*--- Start of INS: USSHIA16/DS1K926511

* Change scenario determination logic

* Pass the  BCN_NUMBER that is sent as input to BUT000 table,

* pick the GUID field. Pass this GUID field to CVI_CUST_LINK table,

* if an entry exists - pick the CUSTOMER field => This is the BP number,

* as it exists already: this will be change scenario.

*If no CUSTOMER is found, this will be creation scenario.

  v_action = zcl_business_partner_ops=>c_task.

  select single partner_guid                                "#EC WARNOK

    from but000

    into @data(lv_partner_guid)

    where bpext = @lwa_bp_create-bcn_num.

  if sy-subrc is initial and lv_partner_guid is not initial .

    select single customer

      from cvi_cust_link

      into @data(lv_customer)

      where partner_guid = @lv_partner_guid.

    if sy-subrc is initial and lv_customer is not initial .

      v_action = zcl_business_partner_ops=>c_task1.

      lwa_bp_create-bu_partner = lv_customer.

    endif.

  endif.

* Source determination logic

* IM_COUNTRY_CODE will determine the source

*(the values are SG for ECC and  MX for Impulse)

  clear: lv_src_impulse, lv_src_ecc.

  if im_country_code = lc_sg .

    lv_src_ecc = abap_true.

  elseif im_country_code = lc_mx.

    lv_src_impulse = abap_true.

    lwa_bp_create-partn_grp = lc_ztr1.

*     Only default the values, if create/change of those role is expected

    if im_ccode_create is not initial.

      im_ccode_create-comp_code = lv_value.

    endif.

    if im_sales_create is not initial.

      im_sales_create-sales_org = '6021'.

    endif.

