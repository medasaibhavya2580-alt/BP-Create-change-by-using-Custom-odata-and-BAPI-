          lwa_return-parameter = zcl_ts_constants=>c_para_bupa.
          append lwa_return to re_return.
          clear lwa_return.
        elseif ev_xerror is not initial.
          message i015(zotc_bp) into lwa_return-message.
          mac_sy_messages lwa_return.
          lwa_return-parameter = zcl_ts_constants=>c_para_bupa.
          append lwa_return to re_return.
          clear lwa_return.
        endif.
      endif.
      clear: create_ma_parent, only_ma_child, c_mabeg, c_assnf, c_valfr_aga,
             wa_ma_bp_di, wa_ma_ag_di, wa_ma_agi_di, wa_ma_aga_di, is_header,
             is_ma_h_di, it_ma_bp_di[], it_ma_ag_di[], it_ma_agi_di[], it_ma_aga_di[],
             lv_bupnm, lv_makey, lv_child_bp_1, lv_child_bp_2,
*             lv_ca,
             c_v_mabeg, c_v_maend,
             v_mabeg, v_maend, v_name, v_name_1, v_exists_bp, v_exists_h.
    else .
      message e000(zotc_bp) with text-b05 into lwa_return-message.
      mac_sy_messages lwa_return.
      lwa_return-parameter = zcl_ts_constants=>c_para_bupa.
