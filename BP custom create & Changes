  endif.  ""
  if re_return is  not initial.
    read table re_return into lwa_return with key type = 'E'.
    if sy-subrc eq 0.
      clear: lv_extnumber.
      concatenate ex_bcn_num ex_suffix into lv_extnumber separated by '-'.
      select object, subobject, extnumber, lognumber from balhdr into table @data(li_balhdr1)
              where object = @zcl_sw_constants=>c_log_obj
                and subobject = @zcl_sw_constants=>c_log_sub_obj
                and extnumber = @lv_extnumber.
      if sy-subrc is initial and li_balhdr1[] is not initial.
        data(lv_operation)                    = zcl_sw_constants=>c_create.
      else.
        lv_status      = zcl_sw_constants=>c_fail.
      endif.
      if  lv_status eq zcl_sw_constants=>c_fail.
        lo_log1 = new zcl_log_maint( ).
        check lo_log1 is bound.
        clear: lv_extnumber.
        concatenate ex_bcn_num ex_suffix into lv_extnumber separated by '-'.
        lv_err_msg = lwa_return-message.
        lo_log1->create_log(
          exporting
            im_extnumber =  lv_extnumber               " Object Number
            im_msg       =  lv_err_msg              " Error Message
        importing
          ex_log_no      =  li_log_no                " Application Log: Newly-Assigned LOGNUMBER Table
        ).
      else.
        loop at li_balhdr1 reference into data(lr_balhdr1).
          clear: lv_extnumber.
          concatenate ex_bcn_num ex_suffix into lv_extnumber separated by '-'.
          lv_log_no = lr_balhdr1->lognumber.
          if not lo_log1 is bound.
            lo_log1 = new zcl_log_maint( ).
          endif.
          lo_log1->delete_log(
                  exporting
                    im_log_no    =   lv_log_no                  " Log Number
